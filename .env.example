# Gemini - chave secreta para o servidor gerar descrições com IA
# Nunca expor esta chave ao browser (sem prefixo NEXT_PUBLIC_)
GEMINI_API_KEY=

# Mapbox - token publico (pk.) para o cliente renderizar o mapa
NEXT_PUBLIC_MAPBOX_TOKEN=

# Mapbox - token secreto (sk.) para o servidor chamar o MCP Server
# Nunca expor este token ao browser
MAPBOX_ACCESS_TOKEN=