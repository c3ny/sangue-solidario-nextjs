# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Segredo para assinar cookies de sessão (NextAuth / iron-session)
# Gerar com: openssl rand -hex 32
COOKIE_SECRET=

# Deve ser IGUAL ao JWT_SECRET de todos os microsserviços
JWT_SECRET=

# ─── URLs DOS MICROSSERVIÇOS ──────────────────────────────────────────────────
# Vars NEXT_PUBLIC_* são expostas ao browser (apenas URLs públicas)
# Vars sem prefixo são usadas apenas no servidor (Server Components / API Routes)

NEXT_PUBLIC_USERS_SERVICE_URL=http://localhost:3002
USERS_SERVICE_URL=http://localhost:3002

NEXT_PUBLIC_DONATION_SERVICE_URL=http://localhost:3001
DONATION_SERVICE_URL=http://localhost:3001

NEXT_PUBLIC_BLOOD_STOCK_SERVICE_URL=http://localhost:3004
BLOOD_STOCK_SERVICE_URL=http://localhost:3004

NEXT_PUBLIC_CDN_SERVICE_URL=http://localhost:3005
CDN_SERVICE_URL=http://localhost:3005

# ─── MAPBOX ───────────────────────────────────────────────────────────────────
# Token público (pk.) — exposto ao browser para renderizar o mapa
NEXT_PUBLIC_MAPBOX_TOKEN=

# Token secreto (sk.) — usado apenas no servidor (ex: Mapbox MCP Server)
# NUNCA usar prefixo NEXT_PUBLIC_ aqui
MAPBOX_ACCESS_TOKEN=

# ─── GEMINI ───────────────────────────────────────────────────────────────────
# Chave para o servidor gerar descrições com IA
# NUNCA usar prefixo NEXT_PUBLIC_ aqui
GEMINI_API_KEY=

# ─── OAUTH ─────────────────────────────────────────────────────────────────────
# Google OAuth — Client ID público (usado no frontend para o botão de login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Apple Sign In — Service ID configurado no Apple Developer Console
NEXT_PUBLIC_APPLE_CLIENT_ID=

# URL pública do site (usada como redirectURI no Apple Sign In)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────
NEXT_PUBLIC_FEATURE_BLOG=false
NEXT_PUBLIC_FEATURE_ABOUT_US=true
NEXT_PUBLIC_FEATURE_CAMPAIGNS=false    # habilitar quando campaign-service estiver pronto
NEXT_PUBLIC_FEATURE_APPOINTMENTS=false # habilitar quando appointments API estiver pronta
